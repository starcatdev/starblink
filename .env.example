# ===== REQUIRED (build fails without these) =====

# Helius RPC (free account at helius.dev)
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Platform wallet (receives 0.5% without referrer, 0.3% with referrer)
PLATFORM_WALLET=YOUR_SOLANA_WALLET_ADDRESS

# ===== OPTIONAL =====

# Fees in basis points (100 bps = 1%). Total is always PLATFORM + REFERRER.
PLATFORM_FEE_BPS=30
REFERRER_FEE_BPS=20

# Public URL (auto-set by Vercel in prod)
NEXT_PUBLIC_URL=http://localhost:3000

# GitHub repo URL (shown in trust block)
NEXT_PUBLIC_GITHUB_URL=https://github.com/starcatdev/starblink
